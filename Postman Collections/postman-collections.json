	"item": [
		{
			"name": "Usuarios",
			"item": [
				{
					"name": "Consulta de usuários por ID",
					"id": "208bf9b2-970b-421d-84b0-678ed4090bab",
					"protocolProfileBehavior": {
						"disableBodyPruning": true
					},
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/usuarios/{{idNewUser}}"
					},
					"response": []
				},
				{
					"name": "Cadastro de usuário",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "89790498-b83a-4616-ae9e-0c7ac63f3a35",
								"exec": [
									"// Parsing the response returned by the request.\r",
									"var jsonData = pm.response.json();\r",
									"\r",
									"// Extracting the token from the response and setting it as an environment variable.\r",
									"pm.environment.set(\"idNewUser\", jsonData._id);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"id": "3126ea98-e514-4102-ab6f-57e6bf8c80fd",
					"protocolProfileBehavior": {
						"disableBodyPruning": true
					},
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"nome\": {{nome}},\r\n    \"email\": {{email}},\r\n    \"password\": {{password}},\r\n    \"administrador\": \"true\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/usuarios"
					},
					"response": []
				}
			],
			"id": "ed719e31-bf36-466e-a458-c44ee580bcfd"
		},
		{
			"name": "Login",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "46d25dc7-d607-4c9d-861e-da1e25611259",
								"exec": [
									"// Parsing the response returned by the request.\r",
									"var jsonData = pm.response.json();\r",
									"\r",
									"// Extracting the token from the response and setting it as a global variable.\r",
									"pm.globals.set(\"authorization\", jsonData.authorization);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"id": "90c1e41e-be67-4cd5-a5f7-6810fa4f815b",
